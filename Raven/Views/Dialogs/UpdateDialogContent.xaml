<UserControl
    x:Class="Raven.Views.Dialogs.UpdateDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel Spacing="10">
        <TextBlock
            x:Name="StatusMessageTextBlock"
            TextWrapping="Wrap" />

        <CheckBox
            x:Name="StartupPreferenceCheckBox"
            x:Uid="Settings_UpdaterStartupCheckbox" />

        <ProgressBar
            x:Name="StatusProgressBar"
            Minimum="0"
            Maximum="100"
            Value="0"
            Height="6"
            Visibility="Collapsed" />

        <TextBlock
            x:Name="StatusProgressTextBlock"
            Visibility="Collapsed" />
    </StackPanel>
</UserControl>