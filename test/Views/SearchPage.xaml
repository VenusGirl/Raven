<Page
    x:Class="test.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:StoreListings.Library"
    xmlns:shared="using:test.Views.Shared"
    xmlns:vm="using:test.ViewModels">

    <shared:CardViewControl
        x:Name="CardView"
        HeaderText="{x:Bind ViewModel.HeaderText, Mode=OneWay}"
        ItemSourceFilter1="{x:Bind ViewModel.ItemSourceFilter1}"
        ItemSourceFilter2="{x:Bind ViewModel.ItemSourceFilter2}"
        ItemsSource="{x:Bind ViewModel.Cards, Mode=OneWay}" />
</Page>
