<Page
    x:Class="test.Views.BundlesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:StoreListings.Library"
    mc:Ignorable="d">
    <ScrollViewer>
        <ScrollViewer.Resources>
            <!--  UniformGridLayout for ItemsRepeater  -->
            <UniformGridLayout
                x:Key="UniformGridLayout"
                ItemsJustification="SpaceEvenly"
                ItemsStretch="Fill"
                MinColumnSpacing="17"
                MinItemHeight="224"
                MinItemWidth="300"
                MinRowSpacing="32" />

            <!--  DataTemplate for displaying each card  -->
            <DataTemplate x:Key="NormalItemTemplate" x:DataType="models:Card">
                <Grid
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    PointerEntered="element_PointerEntered"
                    PointerExited="element_PointerExited"
                    Tag="{x:Bind ProductId}"
                    Tapped="Card_Tapped">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="4*" />
                        <RowDefinition Height="3*" />
                    </Grid.RowDefinitions>
                    <!--  Image Section  -->
                    <Border Background="{x:Bind Image.BackgroundColor}" CornerRadius="8,8,0,0">
                        <Grid>
                            <Image Source="{x:Bind Image.Url}" Stretch="Fill" />
                            <Rectangle Fill="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}" />
                            <Border
                                Width="80"
                                Height="80"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{x:Bind Image.BackgroundColor}"
                                CornerRadius="10">
                                <Image Source="{x:Bind Image.Url}" Stretch="Fill" />
                            </Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Padding="10">
                        <!--  Title Section  -->
                        <TextBlock
                            Height="50"
                            MaxLines="2"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind Title, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                        <Grid Height="50">
                            <!--  Rating Section  -->
                            <StackPanel
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Orientation="Horizontal"
                                Visibility="{x:Bind AverageRating, Mode=OneWay, Converter={StaticResource HideElementConverter}}">
                                <TextBlock
                                    FontSize="13"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind AverageRating, Mode=OneWay, Converter={StaticResource OneDecimalPlaceConverter}}" />
                                <TextBlock
                                    Margin="4,0,0,0"
                                    FontSize="13"
                                    Foreground="#FFB900"
                                    Text="★" />
                            </StackPanel>
                            <!--  Price Section  -->
                            <Border
                                Padding="6,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="5"
                                Visibility="{x:Bind DisplayPrice, Mode=OneWay, Converter={StaticResource HideElementConverter}}">
                                <TextBlock
                                    FontSize="13"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind DisplayPrice, Mode=OneWay}" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </ScrollViewer.Resources>

        <Grid>

            <StackPanel
                x:Name="LoadingOverlay"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.9">
                <ProgressRing
                    Width="50"
                    Height="50"
                    Background="LightGray"
                    IsActive="True" />
                <TextBlock
                    Margin="0,12,0,0"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Loading..." />
            </StackPanel>

            <StackPanel
                x:Name="ErrorIcon"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <FontIcon
                    FontSize="55"
                    Foreground="{ThemeResource AccentAAFillColorDefaultBrush}"
                    Glyph="&#xEB90;" />
                <TextBlock
                    x:Name="ErrorIconText"
                    Margin="0,12,0,0"
                    FontSize="16"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="An Unexpected Error Occured!" />
            </StackPanel>

            <StackPanel
                x:Name="DisplayItem"
                Margin="{StaticResource NavigationViewPageContentMargin}"
                Padding="16">
                <!--  App Details Section  -->
                <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                    <!--  App Icon  -->
                    <Border
                        Width="80"
                        Height="120"
                        Margin="0,0,12,0"
                        CornerRadius="10">
                        <Image Source="{x:Bind AppData.Logo.Url, Mode=OneWay}" Stretch="Fill" />
                    </Border>
                    <StackPanel>
                        <!--  App Name and Publisher  -->
                        <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="{x:Bind AppData.Title, Mode=OneWay}" />
                        <TextBlock
                            FontSize="14"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Text="{x:Bind AppData.PublisherName, Mode=OneWay}" />

                        <!--  Rating Section  -->
                        <StackPanel
                            Margin="0,12,0,0"
                            Orientation="Horizontal"
                            Visibility="{x:Bind AppData.RatingCount, Converter={StaticResource HideElementConverter}}">
                            <TextBlock
                                Margin="4,0"
                                FontSize="14"
                                Text="{x:Bind AppData.Rating, Mode=OneWay, Converter={StaticResource OneDecimalPlaceConverter}}" />
                            <FontIcon
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Glyph="&#xE735;" />
                            <TextBlock
                                Margin="8,0"
                                FontSize="14"
                                Foreground="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Text="|" />
                            <TextBlock FontSize="14" Text="{x:Bind AppData.RatingCount, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!--  Sub heading Section  -->
                <TextBlock
                    Margin="0,25"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="In this bundle" />
                <!--  ItemRepeater Section  -->
                <ItemsRepeater
                    ItemTemplate="{StaticResource NormalItemTemplate}"
                    ItemsSource="{x:Bind BundleCards, Mode=OneWay}"
                    Layout="{StaticResource UniformGridLayout}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
